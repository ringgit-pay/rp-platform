; Angular 21 / Storybook 10 peer mismatch (legacy @angular/platform-browser-dynamic).
legacy-peer-deps=true

; ---- GITHUB PACKAGES REGISTRY ----
; Publishes @rp/* to https://npm.pkg.github.com/govindfsd
; NODE_AUTH_TOKEN is set automatically by actions/setup-node in CI.
; Locally: export NODE_AUTH_TOKEN=<your PAT with read:packages scope>
@rp:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
